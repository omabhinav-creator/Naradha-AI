{
  "manifest_version": 3,
  "name": "Naradha AI Companion",
  "version": "1.0",
  "description": "Omnipresent Slang-Robust Context Sidebar",
  "permissions": ["activeTab", "tabs", "storage", "scripting", "sidePanel"],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*",
    "https://text.pollinations.ai/*",
    "https://image.pollinations.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open Naradha Side Panel"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}