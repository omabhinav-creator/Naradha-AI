{
  "manifest_version": 3,
  "name": "Naradha AI Companion",
  "version": "1.0",
  "description": "Omnipresent Slang-Robust Context Sidebar",
  "permissions": ["activeTab", "tabs", "storage", "sidePanel"],
"host_permissions": [
    "https://api.gnani.ai/*",
    "https://api.getalchemystai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open Naradha Side Panel"
  }
}